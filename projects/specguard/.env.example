# SpecGuard local-first defaults. Copy to .env if you want to override them.
SPECGUARD_PROVIDER=ollama
SPECGUARD_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Optional cloud comparison paths.
# SPECGUARD_PROVIDER=openai
# SPECGUARD_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...

# SPECGUARD_PROVIDER=anthropic
# SPECGUARD_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=sk-ant-...

# Optional legacy Deep Agents grader override.
SPECGUARD_GRADER_MODEL=openai:gpt-4.1-mini
